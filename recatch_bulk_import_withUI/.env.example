# Copy this file to `.env` and fill in the values you need.

# Server
RECATCH_BASE_URL=https://test.recatch.cc
RECATCH_TEAM_SLUG=
RECATCH_RECORD_TYPE_ID=0

# Leave blank to derive from RECATCH_BASE_URL.
RECATCH_LOGIN_URL=https://test.recatch.cc/login?redirect=%2Fleads
RECATCH_LEADS_URL=https://test.recatch.cc/leads
RECATCH_IMPORT_URL=https://test.recatch.cc/leads/import?recordTypeId=0

# Input
RECATCH_SOURCE_CSV=
RECATCH_CSV_DIR=data/csv_split
RECATCH_FILE_PREFIX=lead_seed_instance_email_50000_part_
RECATCH_SPLIT_SIZE=1000
RECATCH_MAPPING_FILE=
RECATCH_PROMPT_MAPPING=false
RECATCH_START=1
RECATCH_END=0

# Files
RECATCH_CREDENTIAL_FILE=credentials/recatch_login.txt
RECATCH_STATE_FILE=
RECATCH_LOG_DIR=logs
RECATCH_SCREENSHOT_DIR=screenshots

# Browser
RECATCH_MANUAL_LOGIN_FALLBACK=false
RECATCH_HEADLESS=false
RECATCH_KEEP_OPEN=false
RECATCH_SKIP_COMPLETED=true

# Timing
RECATCH_DELAY_BETWEEN_PARTS=0
RECATCH_UPLOAD_TIMEOUT_SEC=300
