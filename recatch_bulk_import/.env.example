# Shared baseline based on the successful 50,000-lead import on 2026-03-08.
# Dataset used in that run:
# - 50 split CSV files
# - 1,000 rows per file
# - lead_seed_instance_email_50000_part_001.csv ... _050.csv
# Copy those files into `data/csv_split/`.
# Copy this file to `.env`, `.env.test`, or `.env.prod` before running.

# Test server routing used in the validated run.
# `test.recatch.cc` used plain `/leads` routes with no `teamSlug`.
RECATCH_BASE_URL=https://test.recatch.cc
RECATCH_TEAM_SLUG=
RECATCH_RECORD_TYPE_ID=0

# Exact URLs resolved during the validated test import.
# You can leave these blank if you want the CLI to derive them from BASE_URL.
RECATCH_LOGIN_URL=https://test.recatch.cc/login?redirect=%2Fleads
RECATCH_LEADS_URL=https://test.recatch.cc/leads
RECATCH_IMPORT_URL=https://test.recatch.cc/leads/import?recordTypeId=0

# Input dataset settings from the 50,000-row import.
# New recommended flow:
# - put one source CSV in `data/`
# - set RECATCH_SOURCE_CSV
# - the CLI splits it into RECATCH_CSV_DIR using RECATCH_SPLIT_SIZE
# - if RECATCH_MAPPING_FILE is blank and you run in a terminal, the CLI asks for mappings
RECATCH_SOURCE_CSV=
RECATCH_CSV_DIR=data/csv_split
RECATCH_FILE_PREFIX=lead_seed_instance_email_50000_part_
RECATCH_SPLIT_SIZE=1000
RECATCH_MAPPING_FILE=
RECATCH_PROMPT_MAPPING=false
RECATCH_START=1
# 0 means "process through the last detected/generated part".
RECATCH_END=50

# Local files.
RECATCH_CREDENTIAL_FILE=credentials/recatch_login.txt
# Leave blank to auto-create `logs/bulk-import-state-<host>-default.json`.
RECATCH_STATE_FILE=
RECATCH_LOG_DIR=logs
RECATCH_SCREENSHOT_DIR=screenshots

# Browser behavior.
# The validated 2026-03-08 test run succeeded with credential login and no manual fallback.
RECATCH_MANUAL_LOGIN_FALLBACK=false
RECATCH_HEADLESS=false
RECATCH_KEEP_OPEN=false
# Recommended default for shared QA reruns.
RECATCH_SKIP_COMPLETED=true

# Timing.
RECATCH_DELAY_BETWEEN_PARTS=0
RECATCH_UPLOAD_TIMEOUT_SEC=300
