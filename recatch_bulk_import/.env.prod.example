# Production template derived from the validated 2026-03-08 test import settings.
# Replace only the host and, if needed, the team slug.
# Keep the same 50-file dataset unless the upload payload changes.

RECATCH_BASE_URL=https://your-prod-host.example.com
# Leave blank if prod also uses plain `/leads`.
# Set it only when prod uses `?teamSlug=...`.
RECATCH_TEAM_SLUG=
RECATCH_RECORD_TYPE_ID=0

# Leave these blank in most cases so the CLI derives:
# - <base>/login?redirect=%2Fleads
# - <base>/leads
# - <base>/leads/import?recordTypeId=0
# Fill them explicitly only if prod routes differ from the default pattern.
RECATCH_LOGIN_URL=
RECATCH_LEADS_URL=
RECATCH_IMPORT_URL=

# Same dataset pattern used in the validated test import:
# lead_seed_instance_email_50000_part_001.csv ... _050.csv
# For a new one-file upload flow, set RECATCH_SOURCE_CSV and keep RECATCH_SPLIT_SIZE
# aligned with the current Re:catch per-import limit.
RECATCH_SOURCE_CSV=
RECATCH_CSV_DIR=data/csv_split
RECATCH_FILE_PREFIX=lead_seed_instance_email_50000_part_
RECATCH_SPLIT_SIZE=1000
RECATCH_MAPPING_FILE=
RECATCH_PROMPT_MAPPING=false
RECATCH_START=1
RECATCH_END=50

RECATCH_CREDENTIAL_FILE=credentials/recatch_login.txt
# Use a dedicated state file so interrupted prod runs can resume safely.
RECATCH_STATE_FILE=logs/prod-import-state.json
RECATCH_LOG_DIR=logs
RECATCH_SCREENSHOT_DIR=screenshots

# Prod is safer with manual fallback enabled and a slightly longer timeout.
RECATCH_MANUAL_LOGIN_FALLBACK=true
RECATCH_HEADLESS=false
RECATCH_KEEP_OPEN=false
RECATCH_SKIP_COMPLETED=true

RECATCH_DELAY_BETWEEN_PARTS=1
RECATCH_UPLOAD_TIMEOUT_SEC=600
