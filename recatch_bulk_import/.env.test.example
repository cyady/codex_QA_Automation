# Exact test-server settings based on the successful 50,000-lead import on 2026-03-08.
# Fresh full run:
#   RECATCH_START=1
#   RECATCH_END=50
# Smoke test:
#   override with `--start 1 --end 1`

# `test.recatch.cc` does not use `teamSlug` in the leads URL.
RECATCH_BASE_URL=https://test.recatch.cc
RECATCH_TEAM_SLUG=
RECATCH_RECORD_TYPE_ID=0

# These were the exact routes used during the validated run.
RECATCH_LOGIN_URL=https://test.recatch.cc/login?redirect=%2Fleads
RECATCH_LEADS_URL=https://test.recatch.cc/leads
RECATCH_IMPORT_URL=https://test.recatch.cc/leads/import?recordTypeId=0

# Preferred interactive flow:
# - set RECATCH_SOURCE_CSV to a single CSV file
# - keep RECATCH_SPLIT_SIZE=1000 unless Re:catch increases the limit
# - set RECATCH_PROMPT_MAPPING=true to enter mappings in the terminal
RECATCH_SOURCE_CSV=
# Split files are created here, or you can still copy ready-made split files here.
RECATCH_CSV_DIR=data/csv_split
RECATCH_FILE_PREFIX=lead_seed_instance_email_50000_part_
RECATCH_SPLIT_SIZE=1000
RECATCH_MAPPING_FILE=
RECATCH_PROMPT_MAPPING=false
RECATCH_START=1
RECATCH_END=50

RECATCH_CREDENTIAL_FILE=credentials/recatch_login.txt
# Explicit shared state file for resume/retry on the test server.
RECATCH_STATE_FILE=logs/test-import-state.json
RECATCH_LOG_DIR=logs
RECATCH_SCREENSHOT_DIR=screenshots

# The validated full test import completed without manual login fallback.
RECATCH_MANUAL_LOGIN_FALLBACK=false
RECATCH_HEADLESS=false
RECATCH_KEEP_OPEN=false
RECATCH_SKIP_COMPLETED=true

RECATCH_DELAY_BETWEEN_PARTS=0
RECATCH_UPLOAD_TIMEOUT_SEC=300
